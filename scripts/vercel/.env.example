# Vercel project name. Scripts validate the local Vercel link against it.
VERCEL_PROJECT_NAME=storylock-gateway

# Vercel account/scope. For the personal account, scripts do not pass --scope.
VERCEL_SCOPE=iunknow588

# Vercel CLI token. Leave empty to use the local `vercel login` session.
VERCEL_TOKEN=

# Production custom domain.
VERCEL_CUSTOM_DOMAIN=yian.cdao.online

# Bind the custom domain to the deployment after production deploy.
VERCEL_BIND_CUSTOM_DOMAIN=false

# Public gateway URL used by the website and download pages.
STORYLOCK_GATEWAY_PUBLIC_URL=https://yian.cdao.online

# Android host public URL. Leave empty unless direct mode needs it.
STORYLOCK_ANDROID_HOST_URL=

# Android connection mode: relay_url or direct.
STORYLOCK_ANDROID_CONNECT_MODE=relay_url

# Android relay URL. Required only when relay_url mode uses an external relay.
STORYLOCK_ANDROID_RELAY_URL=

# Android app deep link used to finish binding after install.
STORYLOCK_ANDROID_DEEP_LINK=storylock-host://bind

# Shared secret between Android and Gateway. Replace before production deploy.
STORYLOCK_ANDROID_SHARED_SECRET=replace-with-strong-shared-secret

# Registry file path used by the gateway runtime.
STORYLOCK_ANDROID_REGISTRY_FILE=/tmp/storylock-android-registry.json

# Local APK path. Leave empty when using bundled or external download URLs.
STORYLOCK_ANDROID_APK_PATH=

# External Android package download URL.
STORYLOCK_ANDROID_APP_DOWNLOAD_URL=

# Android package metadata.
STORYLOCK_ANDROID_APK_VERSION=0.1.0
STORYLOCK_ANDROID_APK_VERSION_CODE=1
STORYLOCK_ANDROID_APK_CHECKSUM=
STORYLOCK_ANDROID_PACKAGE_KIND=debug
STORYLOCK_ANDROID_RELEASE_CHANNEL=internal

# Optional Android UI links.
STORYLOCK_ANDROID_UI_DOWNLOAD_URL=
STORYLOCK_ANDROID_INSTALL_GUIDE_URL=

# Local Vercel dev port.
STORYLOCK_VERCEL_PORT=4318

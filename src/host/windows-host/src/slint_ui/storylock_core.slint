        in-out property <string> manifest-file-path: "package-manifest.json";
        in-out property <string> encrypted-vault-path: "vault.stlk";
        in-out property <string> resource-catalog-path: "resource-catalog.json";
        in-out property <string> learning-policy-path: "learning-policy.json";
        in-out property <string> export-package-dir: "";
        in-out property <string> temp-draft-label: "Save Draft";
        in-out property <bool> temp-draft-cooling: false;
        property <string> current-title: active-page == 0 ? (is-zh ? "故事草稿" : "Story Draft") : active-page == 1 ? (is-zh ? "24 个问题" : "24 Questions") : active-page == 2 ? (is-zh ? "受保护对象" : "Protected Objects") : active-page == 3 ? (is-zh ? "学习策略设置" : "Learning Policy Settings") : active-page == 4 ? (is-zh ? "导出" : "Export") : active-page == 6 ? (is-zh ? "答案编辑" : "Answer Editor") : active-page == 7 ? (is-zh ? "对象编辑" : "Object Editor") : (is-zh ? "设置" : "Settings");
        callback close-requested();
        callback save-temp-draft();
        callback previous-node();
        callback next-node();
        callback select-node(string);
        callback select-resource-group(string);
        callback select-object(string);
        callback save-resource();
        callback save-template();
        callback apply-template();
        callback pull-template-candidates();
        callback refresh-export();
        callback save-learning-policy();
        callback run-learning();
        callback learning-previous();
        callback learning-next();
        callback export-package();
        callback browse-core-data-dir();
        callback browse-export-package-dir();
        callback open-core-settings();
        callback unlock-current-package();

        title: "StoryLock Core";
        preferred-width: 960px;
        preferred-height: 540px;
        min-width: 960px;
        max-width: 960px;
        min-height: 540px;
        max-height: 540px;
        background: #eef3f5;

        HorizontalBox {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                min-width: 160px;
                max-width: 160px;
                background: #eef3f5;
                VerticalBox {
                    x: 18px;
                    y: 12px;
                    width: 124px;
                    height: 528px;
                    spacing: 7px;
                    MenuButton {
                        label: root.is-zh ? "24 个问题" : "24 Questions";
                        selected: root.active-page == 1;
                        clicked => { root.active-page = 1; }
                    }
                    MenuButton {
                        label: root.is-zh ? "故事草稿" : "Story Draft";
                        selected: root.active-page == 0;
                        clicked => { root.active-page = 0; }
                    }
                    MenuButton {
                        label: root.package-unlocked
                            ? (root.is-zh ? "当前包已解锁" : "Package Unlocked")
                            : (root.is-zh ? "解锁当前包" : "Unlock Package");
                        selected: false;
                        enabled: !root.package-unlocked;
                        clicked => { root.unlock-current-package(); }
                    }
                    MenuButton {
                        label: root.is-zh ? "受保护对象" : "Protected Objects";
                        selected: root.active-page == 2;
                        clicked => { root.active-page = 2; }
                    }
                    SubMenuButton {
                        label: root.is-zh ? "普通对象" : "Normal Objects";
                        selected: root.active-page == 2 && root.resource-group == "normal";
                        clicked => {
                            root.select-resource-group("normal");
                        }
                    }
                    SubMenuButton {
                        label: root.is-zh ? "私密对象" : "Private Objects";
                        selected: root.active-page == 2 && root.resource-group == "private";
                        clicked => {
                            root.select-resource-group("private");
                        }
                    }
                    SubMenuButton {
                        label: root.is-zh ? "机密对象" : "Secret Objects";
                        selected: root.active-page == 2 && root.resource-group == "secret";
                        clicked => {
                            root.select-resource-group("secret");
                        }
                    }
                    MenuButton {
                        label: root.temp-draft-label;
                        selected: false;
                        enabled: root.package-unlocked && !root.temp-draft-cooling;
                        clicked => { root.save-temp-draft(); }
                    }
                    MenuButton {
                        label: root.is-zh ? "学习策略设置" : "Learning Policy";
                        selected: root.active-page == 3;
                        enabled: root.package-unlocked;
                        clicked => { root.active-page = 3; }
                    }
                    MenuButton {
                        label: root.is-zh ? "导出" : "Export";
                        selected: root.active-page == 4;
                        enabled: root.package-unlocked;
                        clicked => { root.active-page = 4; }
                    }
                }
            }

            Rectangle {
                min-width: 800px;
                background: #eef3f5;
                VerticalBox {
                    padding: 24px;
                    spacing: 16px;

                    Rectangle {
                        height: 36px;
                        background: transparent;
                        Image {
                            x: 0px;
                            y: 4px;
                            source: @image-url("../assets/lock.png");
                            width: 28px;
                            height: 28px;
                        }
                        Text {
                            x: 38px;
                            y: 4px;
                            width: 470px;
                            height: 28px;
                            text: "StoryLock Core - " + root.current-title;
                            font-size: 16px;
                            font-weight: 800;
                            color: #17252f;
                            overflow: elide;
                        }
                        SettingsIconButton {
                            x: 688px;
                            y: 2px;
                            selected: false;
                            clicked => { root.open-core-settings(); }
                        }
                    }

                    Rectangle { height: 1px; background: #d7e1e6; }

                    Rectangle {
                        width: 720px;
                        height: 374px;
                        background: #eef3f5;

                        if root.active-page == 0: StoryDraftPage {
                            is-zh: root.is-zh;
                            story-title <=> root.story-title;
                            story-summary <=> root.story-summary;
                            story-plot <=> root.story-plot;
                        }

                        if root.active-page == 1: QuestionOverviewPage {
                            is-zh: root.is-zh;
                            selected-question <=> root.selected-question;
                            selection-enabled: root.overview-selection-enabled;
                            question-1: root.question-1;
                            question-2: root.question-2;
                            question-3: root.question-3;
                            question-4: root.question-4;
                            question-5: root.question-5;
                            question-6: root.question-6;
                            question-7: root.question-7;
                            question-8: root.question-8;
                            question-9: root.question-9;
                            question-10: root.question-10;
                            question-11: root.question-11;
                            question-12: root.question-12;
                            question-13: root.question-13;
                            question-14: root.question-14;
                            question-15: root.question-15;
                            question-16: root.question-16;
                            question-17: root.question-17;
                            question-18: root.question-18;
                            question-19: root.question-19;
                            question-20: root.question-20;
                            question-21: root.question-21;
                            question-22: root.question-22;
                            question-23: root.question-23;
                            question-24: root.question-24;
                            select-node(value) => {
                                root.select-node(value);
                            }
                        }

                        if root.active-page == 6: QuestionEditorPage {
                            is-zh: root.is-zh;
                            selected-question <=> root.selected-question;
                            question-text <=> root.question-text;
                            answer-1 <=> root.answer-1;
                            answer-1-state <=> root.answer-1-state;
                            answer-2 <=> root.answer-2;
                            answer-2-state <=> root.answer-2-state;
                            answer-3 <=> root.answer-3;
                            answer-3-state <=> root.answer-3-state;
                            answer-4 <=> root.answer-4;
                            answer-4-state <=> root.answer-4-state;
                            answer-5 <=> root.answer-5;
                            answer-5-state <=> root.answer-5-state;
                            answer-6 <=> root.answer-6;
                            answer-6-state <=> root.answer-6-state;
                            answer-7 <=> root.answer-7;
                            answer-7-state <=> root.answer-7-state;
                            answer-8 <=> root.answer-8;
                            answer-8-state <=> root.answer-8-state;
                            answer-9 <=> root.answer-9;
                            answer-9-state <=> root.answer-9-state;
                            previous-node => { root.previous-node(); }
                            next-node => { root.next-node(); }
                            select-node(value) => { root.select-node(value); }
                            back-to-overview => { root.active-page = 1; }
                        }

                        if root.active-page == 2: ProtectedObjectsPage {
                            is-zh: root.is-zh;
                            resource-group: root.resource-group;
                            display-name: root.display-name;
                            resource-id: root.resource-id;
                            resource-kind: root.resource-kind;
                            provider-id: root.provider-id;
                            object-id: root.object-id;
                            object-kind: root.object-kind;
                            authorization-frequency: root.authorization-frequency;
                            protected-object-list: root.protected-object-list;
                            object-1-id: root.object-1-id;
                            object-1-name: root.object-1-name;
                            object-1-secret: root.object-1-secret;
                            object-1-usage: root.object-1-usage;
                            object-1-level: root.object-1-level;
                            object-2-id: root.object-2-id;
                            object-2-name: root.object-2-name;
                            object-2-secret: root.object-2-secret;
                            object-2-usage: root.object-2-usage;
                            object-2-level: root.object-2-level;
                            object-3-id: root.object-3-id;
                            object-3-name: root.object-3-name;
                            object-3-secret: root.object-3-secret;
                            object-3-usage: root.object-3-usage;
                            object-3-level: root.object-3-level;
                            object-4-id: root.object-4-id;
                            object-4-name: root.object-4-name;
                            object-4-secret: root.object-4-secret;
                            object-4-usage: root.object-4-usage;
                            object-4-level: root.object-4-level;
                            object-5-id: root.object-5-id;
                            object-5-name: root.object-5-name;
                            object-5-secret: root.object-5-secret;
                            object-5-usage: root.object-5-usage;
                            object-5-level: root.object-5-level;
                            object-6-id: root.object-6-id;
                            object-6-name: root.object-6-name;
                            object-6-secret: root.object-6-secret;
                            object-6-usage: root.object-6-usage;
                            object-6-level: root.object-6-level;
                            object-7-id: root.object-7-id;
                            object-7-name: root.object-7-name;
                            object-7-secret: root.object-7-secret;
                            object-7-usage: root.object-7-usage;
                            object-7-level: root.object-7-level;
                            object-8-id: root.object-8-id;
                            object-8-name: root.object-8-name;
                            object-8-secret: root.object-8-secret;
                            object-8-usage: root.object-8-usage;
                            object-8-level: root.object-8-level;
                            select-object(value) => { root.select-object(value); }
                        }

                        if root.active-page == 3: LearningPage {
                            is-zh: root.is-zh;
                            pre-learning-prompts-per-question <=> root.pre-learning-prompts-per-question;
                            pre-learning-error-tolerance <=> root.pre-learning-error-tolerance;
                            weak-item-limit <=> root.weak-item-limit;
                            initial-days <=> root.initial-days;
                            initial-frequency-days <=> root.initial-frequency-days;
                            consolidation-days <=> root.consolidation-days;
                            consolidation-frequency-days <=> root.consolidation-frequency-days;
                            adaptation-weeks <=> root.adaptation-weeks;
                            adaptation-frequency-weeks <=> root.adaptation-frequency-weeks;
                            stable-months <=> root.stable-months;
                            stable-frequency-months <=> root.stable-frequency-months;
                            long-term-years <=> root.long-term-years;
                            long-term-frequency-years <=> root.long-term-frequency-years;
                            learning-plan-summary: root.learning-plan-summary;
                            learning-status: root.learning-status;
                            save-learning-policy => { root.save-learning-policy(); }
                        }

                        if root.active-page == 4: ExportPage {
                            is-zh: root.is-zh;
                            learning-plan-summary: root.learning-plan-summary;
                            learning-status: root.learning-status;
                            learning-progress-summary: root.learning-progress-summary;
                            learning-action-hint: root.learning-action-hint;
                            learning-result: root.learning-result;
                            config-status: root.config-status;
                            export-ready: root.export-ready;
                            run-learning => { root.run-learning(); }
                            export-package => { root.export-package(); }
                        }

                    }
                }
            }
        }
    }



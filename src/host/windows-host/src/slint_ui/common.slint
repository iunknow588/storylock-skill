export component LearningAnswerTile inherits Rectangle {
        in property <string> value;
        in-out property <string> state;
        callback toggle-requested();

        width: 237px;
        height: 66px;
        border-width: 1px;
        border-color: state == "correct" ? #7fb38d : (touch-main.has-hover || touch-mark.has-hover ? #b7c6cc : #d7e1e6);
        border-radius: 6px;
        background: state == "correct" ? #edf7f0 : (touch-main.pressed || touch-mark.pressed ? #edf3f5 : #ffffff);

        Text {
            x: 10px;
            y: 8px;
            width: parent.width - 76px;
            height: parent.height - 16px;
            text: root.value;
            color: #17252f;
            font-size: 13px;
            vertical-alignment: top;
            wrap: word-wrap;
            overflow: elide;
        }

        BinaryStateCheckBox {
            x: parent.width - 62px;
            y: parent.height - 34px;
            width: 60px;
            height: 32px;
            state <=> root.state;
            show-label: false;
            show-frame: false;
            interactive: false;
            correct-label: "打勾";
            wrong-label: "打叉";
        }

        touch-main := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width - 76px;
            height: parent.height;
            double-clicked => {
                root.toggle-requested();
            }
        }

        touch-mark := TouchArea {
            x: parent.width - 62px;
            y: parent.height - 34px;
            width: 60px;
            height: 32px;
            clicked => {
                root.toggle-requested();
            }
        }
    }

export component LearningAnswerGrid inherits Rectangle {
        in property <string> answer-1;
        in-out property <string> answer-1-state;
        in property <string> answer-2;
        in-out property <string> answer-2-state;
        in property <string> answer-3;
        in-out property <string> answer-3-state;
        in property <string> answer-4;
        in-out property <string> answer-4-state;
        in property <string> answer-5;
        in-out property <string> answer-5-state;
        in property <string> answer-6;
        in-out property <string> answer-6-state;
        in property <string> answer-7;
        in-out property <string> answer-7-state;
        in property <string> answer-8;
        in-out property <string> answer-8-state;
        in property <string> answer-9;
        in-out property <string> answer-9-state;
        callback toggle-answer(int);

        width: 724px;
        height: 210px;
        background: transparent;

        GridLayout {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            spacing: 6px;

            Row {
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-1; state <=> root.answer-1-state; toggle-requested => { root.toggle-answer(0); } }
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-2; state <=> root.answer-2-state; toggle-requested => { root.toggle-answer(1); } }
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-3; state <=> root.answer-3-state; toggle-requested => { root.toggle-answer(2); } }
            }
            Row {
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-4; state <=> root.answer-4-state; toggle-requested => { root.toggle-answer(3); } }
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-5; state <=> root.answer-5-state; toggle-requested => { root.toggle-answer(4); } }
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-6; state <=> root.answer-6-state; toggle-requested => { root.toggle-answer(5); } }
            }
            Row {
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-7; state <=> root.answer-7-state; toggle-requested => { root.toggle-answer(6); } }
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-8; state <=> root.answer-8-state; toggle-requested => { root.toggle-answer(7); } }
                LearningAnswerTile { width: (root.width - 12px) / 3; height: (root.height - 12px) / 3; value: root.answer-9; state <=> root.answer-9-state; toggle-requested => { root.toggle-answer(8); } }
            }
        }
}

export component StaticTextPanel inherits Rectangle {
        in property <string> value;
        in property <length> panel-height: 60px;

        width: 690px;
        height: root.panel-height;
        border-radius: 6px;
        border-width: 1px;
        border-color: #d7e1e6;
        background: #ffffff;

        Text {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            height: parent.height - 16px;
            text: root.value;
            color: #17252f;
            font-size: 12px;
            wrap: word-wrap;
            vertical-alignment: top;
        }
    }

export component QuestionConfigPanel inherits Rectangle {
        in property <length> panel-height: 374px;
        in-out property <string> selected-question;
        in-out property <string> question-text;
        in-out property <string> answer-1;
        in-out property <string> answer-1-state;
        in-out property <string> answer-2;
        in-out property <string> answer-2-state;
        in-out property <string> answer-3;
        in-out property <string> answer-3-state;
        in-out property <string> answer-4;
        in-out property <string> answer-4-state;
        in-out property <string> answer-5;
        in-out property <string> answer-5-state;
        in-out property <string> answer-6;
        in-out property <string> answer-6-state;
        in-out property <string> answer-7;
        in-out property <string> answer-7-state;
        in-out property <string> answer-8;
        in-out property <string> answer-8-state;
        in-out property <string> answer-9;
        in-out property <string> answer-9-state;
        callback previous-node();
        callback next-node();
        callback select-node(string);

        width: 740px;
        height: root.panel-height;
        border-radius: 6px;
        border-width: 0px;
        background: transparent;

        ScrollView {
            x: 10px;
            y: 0px;
            width: 720px;
            height: root.panel-height;
            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
            viewport-width: 720px;
            viewport-height: 520px;
            VerticalBox {
                x: 0px;
                y: 0px;
                width: 690px;
                height: 520px;
                spacing: 8px;
                QuestionIdTableRow {
                    selected-question <=> root.selected-question;
                    previous-node => { root.previous-node(); }
                    next-node => { root.next-node(); }
                    select-node(value) => { root.select-node(value); }
                }
                QuestionTableRow { label: "Name"; value <=> root.question-text; state: ""; show-state: false; }
                QuestionTableRow { label: "Answer 1"; value <=> root.answer-1; state <=> root.answer-1-state; show-state: true; }
                QuestionTableRow { label: "Answer 2"; value <=> root.answer-2; state <=> root.answer-2-state; show-state: true; }
                QuestionTableRow { label: "Answer 3"; value <=> root.answer-3; state <=> root.answer-3-state; show-state: true; }
                QuestionTableRow { label: "Answer 4"; value <=> root.answer-4; state <=> root.answer-4-state; show-state: true; }
                QuestionTableRow { label: "Answer 5"; value <=> root.answer-5; state <=> root.answer-5-state; show-state: true; }
                QuestionTableRow { label: "Answer 6"; value <=> root.answer-6; state <=> root.answer-6-state; show-state: true; }
                QuestionTableRow { label: "Answer 7"; value <=> root.answer-7; state <=> root.answer-7-state; show-state: true; }
                QuestionTableRow { label: "Answer 8"; value <=> root.answer-8; state <=> root.answer-8-state; show-state: true; }
                QuestionTableRow { label: "Answer 9"; value <=> root.answer-9; state <=> root.answer-9-state; show-state: true; }
            }
        }
    }

export component ActionButton inherits Rectangle {
        in property <string> label;
        in property <bool> primary;
        in property <bool> enabled: true;
        in property <bool> danger: false;
        in property <length> button-width: 150px;
        in property <length> button-height: 34px;
        callback clicked();

        width: root.button-width;
        height: root.button-height;
        border-radius: 6px;
        border-width: 1px;
        border-color: !enabled ? #d8e0e4 : (danger ? #b94d4d : (primary ? #45606b : #c9d5da));
        background: !enabled ? #d8e0e4 : (danger ? (touch.pressed ? #9f3f3f : (touch.has-hover ? #b94d4d : #c45c5c)) : (primary ? (touch.pressed ? #344b54 : (touch.has-hover ? #3a5a66 : #45606b)) : (touch.pressed ? #c9d5da : (touch.has-hover ? #dfe8ec : #f7fafb))));
        touch := TouchArea {
            enabled: root.enabled;
            clicked => { root.clicked(); }
        }
        Text {
            text: root.label;
            width: parent.width;
            height: parent.height;
            color: !enabled ? #8a98a0 : (primary || danger ? white : #17252f);
            font-size: 13px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

export component SettingsIconButton inherits Rectangle {
        in property <bool> selected;
        callback clicked();

        width: 32px;
        height: 32px;
        border-radius: 6px;
        border-width: 1px;
        border-color: selected ? #45606b : #c9d5da;
        background: selected ? #d7e1e6 : (touch.pressed ? #d7e1e6 : (touch.has-hover ? #edf3f5 : #f7fafb));
        touch := TouchArea {
            clicked => { root.clicked(); }
        }
        Text {
            text: "⚙";
            width: parent.width;
            height: parent.height;
            color: #17252f;
            font-size: 18px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

export component SectionTitle inherits Text {
        in property <string> label;

        text: root.label;
        height: 20px;
        color: #17252f;
        font-size: 14px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

export component SectionPanel inherits Rectangle {
        in property <length> panel-width: 564px;
        in property <length> panel-height: 96px;

        width: root.panel-width;
        height: root.panel-height;
        border-radius: 6px;
        border-width: 1px;
        border-color: #d7e1e6;
        background: #ffffff;
    }

export component StaticRow inherits HorizontalLayout {
        in property <string> name;
        in property <string> value;
        in property <length> value-width: 390px;
        in property <length> row-height: 32px;
        spacing: 14px;
        Text {
            text: root.name;
            width: 150px;
            height: root.row-height;
            color: #62727d;
            font-size: 13px;
            vertical-alignment: center;
        }
        Rectangle {
            width: root.value-width;
            height: root.row-height;
            border-radius: 4px;
            border-width: 1px;
            border-color: #d7e1e6;
            background: #ffffff;
            Text {
                x: 10px;
                width: parent.width - 20px;
                height: parent.height;
                text: root.value;
                color: #17252f;
                font-size: 13px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

export component LogPanel inherits Rectangle {
        in property <string> value;
        in property <length> panel-height: 300px;
        height: root.panel-height;
        border-radius: 6px;
        border-width: 1px;
        border-color: #c9d5da;
        background: #f7fafb;
        Text {
            x: 12px;

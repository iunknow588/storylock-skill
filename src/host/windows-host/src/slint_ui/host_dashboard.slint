import { Button, ComboBox, LineEdit, ScrollView, TextEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { MenuButton, SideActionButton, SubMenuButton, InfoRow, FormRow, EditableRow, PathBrowseRow, LargeEditableText, QuestionTableRow, QuestionIdTableRow, QuestionOverviewGrid, QuestionConfigPanel, ActionButton, ToggleSwitch, StatusBadge, SettingsIconButton, SectionPanel, SectionTitle, StaticRow, LogPanel, LearningAnswerGrid } from "common.slint";

export component AuthorizationSummaryRow inherits Rectangle {
        in property <bool> is-header: false;
        in property <string> object-name;
        in property <string> action-name;
        in property <string> strength;
        in property <string> result;

        width: 520px;
        height: 30px;
        border-width: 1px;
        border-color: root.is-header ? #b8c8cd : #d7e1e6;
        background: root.is-header ? #d7e1e6 : #ffffff;

        Text {
            x: 8px;
            y: 0px;
            width: 160px;
            height: parent.height;
            text: root.object-name;
            color: #17252f;
            font-size: 12px;
            font-weight: root.is-header ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
        }
        Text {
            x: 176px;
            y: 0px;
            width: 86px;
            height: parent.height;
            text: root.action-name;
            color: #17252f;
            font-size: 12px;
            font-weight: root.is-header ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
        }
        Text {
            x: 270px;
            y: 0px;
            width: 116px;
            height: parent.height;
            text: root.strength;
            color: #17252f;
            font-size: 12px;
            font-weight: root.is-header ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
        }
        Text {
            x: 394px;
            y: 0px;
            width: 118px;
            height: parent.height;
            text: root.result;
            color: root.is-header ? #17252f : #5a6b75;
            font-size: 12px;
            font-weight: root.is-header ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
        }
    }

export component HostDashboard inherits Window {
        in-out property <int> active-page: 0;
        in-out property <string> language: "zh";
        property <bool> is-zh: language == "zh";
        in-out property <bool> settings-open: false;
        in-out property <string> nine-grid-status: "\u{4e5d}\u{5bab}\u{683c}\u{6d4b}\u{8bd5}\u{5c1a}\u{672a}\u{5f00}\u{59cb}";
        in-out property <bool> nine-grid-running: false;
        in-out property <string> storylock-data-dir: "";
        in property <string> product;
        in property <string> version;
        in property <string> mode;
        in property <string> identity-id;
        in property <string> device-id;
        in property <string> management-stats;
        in property <string> diagnostics;
        in property <string> status-summary;
        in property <string> package-self-check;
        in-out property <string> connection-test-status: "No connection test has run yet.";
        in-out property <string> connection-test-badge-label: "Idle";
        in-out property <string> connection-test-badge-tone: "neutral";
        in-out property <bool> connection-test-running: false;
        in-out property <bool> remote-relay-enabled: false;
        in-out property <bool> remote-restart-required: false;
        in-out property <string> gateway-url: "https://yian.cdao.online";
        in-out property <string> remote-config-status: "Remote relay changes are saved for next restart.";
        in-out property <string> nine-grid-badge-label: "\u{672a}\u{5f00}\u{59cb}";
        in-out property <string> nine-grid-badge-tone: "neutral";
        property <string> current-title:
            active-page == 0 ? (is-zh ? "\u{8fdc}\u{7aef} Web \u{63a5}\u{53e3}\u{914d}\u{7f6e}" : "Remote Web Interface") :
            active-page == 1 ? (is-zh ? "\u{5e95}\u{5c42} StoryLock \u{914d}\u{7f6e}" : "StoryLock Core") :
            active-page == 2 ? (is-zh ? "\u{8c03}\u{8bd5}\u{6982}\u{89c8}" : "Debug Overview") :
            active-page == 3 ? (is-zh ? "\u{8fde}\u{63a5}\u{8054}\u{8c03}\u{6d4b}\u{8bd5}" : "Connection Tests") :
            (is-zh ? "\u{4e5d}\u{5bab}\u{683c}\u{6388}\u{6743}\u{6d4b}\u{8bd5}" : "Nine-Grid Tests");
        callback close-requested();
        callback open-storylock-core();
        callback open-settings();
        callback browse-storylock-data-dir();
        callback test-local-host();
        callback test-remote-connection();
        callback save-remote-web-config(bool, string) -> string;
        callback restart-windows-host() -> string;
        callback test-managed-object-nine-grid(string) -> string;

        title: "Yian Windows Host";
        icon: @image-url("../assets/lock.png");
        preferred-width: 960px;
        preferred-height: 540px;
        background: #eef3f5;

        HorizontalBox {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                min-width: 180px;
                max-width: 180px;
                background: #dfe9ec;
                Rectangle {
                    x: parent.width - 1px;
                    y: 0px;
                    width: 1px;
                    height: parent.height;
                    background: #c9d5da;
                }

                VerticalBox {
                    x: 18px;
                    y: 32px;
                    width: 144px;
                    height: 372px;
                    spacing: 12px;

                    Rectangle {
                        width: 144px;
                        height: 32px;
                        background: transparent;
                        Text {
                            x: 0px;
                            y: 0px;
                            width: 102px;
                            height: parent.height;
                            text: root.is-zh ? "\u{6613}\u{5b89}" : "StoryLock";
                            color: #17252f;
                            font-size: 22px;
                            font-weight: 800;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        SettingsIconButton {
                            x: 112px;
                            y: 0px;
                            selected: false;
                            clicked => { root.open-settings(); }
                        }
                    }

                    Text {
                        text: root.is-zh ? "StoryLock Host" : "Local Host";
                        width: 144px;
                        height: 20px;
                        color: #5a6b75;
                        font-size: 13px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    Rectangle {
                        width: 144px;
                        height: 1px;
                        background: #c9d5da;
                    }

                    MenuButton {
                        label: root.is-zh ? "\u{8fdc}\u{7aef} Web" : "Remote Web";
                        selected: root.active-page == 0;
                        clicked => { root.active-page = 0; }
                    }
                    MenuButton {
                        label: root.is-zh ? "\u{5e95}\u{5c42} StoryLock" : "StoryLock";
                        selected: root.active-page == 1;
                        clicked => { root.active-page = 1; }
                    }
                    MenuButton {
                        label: root.is-zh ? "\u{8c03}\u{8bd5}\u{6d4b}\u{8bd5}" : "Debug And Tests";
                        selected: root.active-page >= 2;
                        clicked => { root.active-page = 2; }
                    }
                    SubMenuButton {
                        label: root.is-zh ? "\u{8c03}\u{8bd5}\u{6982}\u{89c8}" : "Debug Overview";
                        selected: root.active-page == 2;
                        button-height: 28px;
                        clicked => { root.active-page = 2; }
                    }
                    SubMenuButton {
                        label: root.is-zh ? "\u{8fde}\u{63a5}\u{8054}\u{8c03}" : "Connection Tests";
                        selected: root.active-page == 3;
                        button-height: 28px;
                        clicked => { root.active-page = 3; }
                    }
                    SubMenuButton {
                        label: root.is-zh ? "\u{4e5d}\u{5bab}\u{683c}\u{6d4b}\u{8bd5}" : "Nine-Grid Tests";
                        selected: root.active-page == 4;
                        button-height: 28px;
                        clicked => { root.active-page = 4; }
                    }
                    Rectangle {
                        width: 144px;
                        height: 1px;
                        background: #c9d5da;
                    }
                    SideActionButton {
                        label: root.is-zh ? "\u{6253}\u{5f00} StoryLock" : "Open StoryLock";
                        clicked => { root.open-storylock-core(); }
                    }
                }
            }

            Rectangle {
                min-width: 640px;
                background: #f7fafb;
                Rectangle {
                    width: 640px;
                    height: 540px;
                    background: #ffffff;
                    VerticalBox {
                        padding-left: 38px;
                        padding-right: 38px;
                        padding-top: 26px;
                        padding-bottom: 28px;
                        spacing: 12px;

                        Rectangle {
                            height: 38px;
                            background: transparent;
                            Text {
                                x: 0px;
                                y: 2px;
                                width: 564px;
                                height: 20px;
                                text: "Yian: StoryLock - " + root.current-title;
                                font-size: 17px;
                                font-weight: 700;
                                color: #17252f;
                                overflow: elide;
                            }
                            Text {
                                x: 0px;
                                y: 23px;
                                width: 564px;
                                height: 14px;
                                text: root.is-zh ? "\u{672c}\u{673a}\u{6388}\u{6743}\u{3001}\u{72b6}\u{6001}\u{89c2}\u{5bdf}\u{4e0e} StoryLock \u{5165}\u{53e3}" : "Local authorization, status observation, and StoryLock entry";
                                font-size: 12px;
                                font-weight: 500;
                                color: #5a6b75;
                                overflow: elide;
                            }
                        }

                        Rectangle {
                            height: 1px;
                            background: #d7e1e6;
                        }

                        Rectangle {
                            width: 600px;
                            height: 372px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #d7e1e6;
                            background: #f7fafb;
                            ScrollView {
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: parent.height;
                                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                viewport-width: 564px;
                                viewport-height: root.active-page == 1 ? 372px : 548px;

                            if root.active-page == 0: VerticalBox {
                                x: 18px;
                                y: 14px;
                                width: 564px;
                                height: 344px;
                                spacing: 6px;
                                Text {
                                    text: root.is-zh ? "\u{8fdc}\u{7aef} Web Relay \u{914d}\u{7f6e}" : "Remote Web Relay Settings";
                                    height: 20px;
                                    color: #17252f;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 96px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 80px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{8fdc}\u{7aef}\u{4e2d}\u{7ee7}" : "Remote Relay";
                                        }
                                        Text {
                                            x: 0px;
                                            y: 28px;
                                            width: 150px;
                                            height: 32px;
                                            text: root.is-zh ? "\u{5141}\u{8bb8}\u{8fdc}\u{7aef} Web \u{8fde}\u{63a5}" : "Enable Remote Web Relay";
                                            color: #62727d;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                        ToggleSwitch {
                                            x: 164px;
                                            y: 28px;
                                            checked <=> root.remote-relay-enabled;
                                            is-zh: root.is-zh;
                                            toggled(value) => {
                                                root.remote-restart-required = true;
                                            }
                                        }
                                        ActionButton {
                                            x: 420px;
                                            y: 30px;
                                            label: root.is-zh ? "\u{91cd}\u{65b0}\u{542f}\u{52a8}" : "Restart";
                                            primary: false;
                                            enabled: root.remote-restart-required;
                                            button-width: 116px;
                                            button-height: 28px;
                                            clicked => {
                                                root.remote-config-status = root.restart-windows-host();
                                            }
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 106px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 90px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: "Gateway URL";
                                        }
                                        EditableRow {
                                            x: 0px;
                                            y: 24px;
                                            name: root.is-zh ? "\u{7f51}\u{5173}\u{5730}\u{5740}" : "Gateway URL";
                                            value <=> root.gateway-url;
                                            editor-width: 372px;
                                            row-height: 30px;
                                        }
                                        ActionButton {
                                            x: 164px;
                                            y: 60px;
                                            label: root.is-zh ? "\u{4fdd}\u{5b58}\u{8fdc}\u{7aef}\u{914d}\u{7f6e}" : "Save Remote Config";
                                            primary: true;
                                            button-width: 180px;
                                            button-height: 28px;
                                            clicked => {
                                                root.remote-config-status = root.save-remote-web-config(root.remote-relay-enabled, root.gateway-url);
                                            }
                                        }
                                    }
                                }
                            }

                            if root.active-page == 1: VerticalBox {
                                x: 18px;
                                y: 14px;
                                width: 564px;
                                height: 352px;
                                spacing: 12px;
                                Text {
                                    text: root.is-zh ? "StoryLock \u{672c}\u{673a}\u{5305}\u{7ba1}\u{63a7}" : "StoryLock Local Package Control";
                                    height: 20px;
                                    color: #17252f;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 84px;
                                    VerticalBox {
                                        x: 14px;
                                        y: 10px;
                                        width: 536px;
                                        height: 62px;
                                        spacing: 10px;
                                        SectionTitle { label: root.is-zh ? "\u{5f53}\u{524d}\u{5305}" : "Current Package"; }
                                        PathBrowseRow {
                                            name: root.is-zh ? "StoryLock \u{52a0}\u{5bc6}\u{5305}" : "StoryLock Package";
                                            value <=> root.storylock-data-dir;
                                            is-zh: root.is-zh;
                                            editor-width: 312px;
                                            row-height: 28px;
                                            browse => { root.browse-storylock-data-dir(); }
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 226px;
                                    VerticalBox {
                                        x: 14px;
                                        y: 10px;
                                        width: 536px;
                                        height: 206px;
                                        spacing: 6px;
                                        SectionTitle { label: root.is-zh ? "\u{6388}\u{6743}\u{7ba1}\u{7406}\u{5bf9}\u{8c61}" : "Authorized Managed Objects"; }
                                        AuthorizationSummaryRow {
                                            is-header: true;
                                            object-name: root.is-zh ? "\u{88ab}\u{63a7}\u{5bf9}\u{8c61}" : "Controlled Object";
                                            action-name: root.is-zh ? "\u{4fdd}\u{5bc6}\u{7ea7}\u{522b}" : "Secrecy";
                                            strength: root.is-zh ? "\u{8bbf}\u{95ee}\u{7b49}\u{7ea7}" : "Access Level";
                                            result: root.is-zh ? "\u{6388}\u{6743}\u{8981}\u{6c42}" : "Auth Rule";
                                        }
                                        ScrollView {
                                            width: 536px;
                                            height: 144px;
                                            vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                                            viewport-width: 520px;
                                            viewport-height: 144px;
                                            VerticalBox {
                                                width: 520px;
                                                height: 144px;
                                                spacing: 1px;
                                                AuthorizationSummaryRow {
                                                    object-name: "windows-credential-ref";
                                                    action-name: root.is-zh ? "\u{79d8}\u{5bc6}" : "secret";
                                                    strength: "password_fill";
                                                    result: "6 / 9 medium";
                                                }
                                                AuthorizationSummaryRow {
                                                    object-name: "windows-signature-key";
                                                    action-name: root.is-zh ? "\u{673a}\u{5bc6}" : "secret";
                                                    strength: "signature";
                                                    result: "6 / 9 medium";
                                                }
                                                AuthorizationSummaryRow {
                                                    object-name: "protected-object-set";
                                                    action-name: root.is-zh ? "\u{9ad8}\u{5bc6}" : "high";
                                                    strength: "batch_read";
                                                    result: "12 / 12 high";
                                                }
                                                AuthorizationSummaryRow {
                                                    object-name: "storylock-local-core";
                                                    action-name: root.is-zh ? "\u{672c}\u{5730}\u{6838}\u{5fc3}" : "local_core";
                                                    strength: "story_edit";
                                                    result: "22 / 24 local";
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            if root.active-page == 2: VerticalBox {
                                x: 18px;
                                y: 14px;
                                width: 564px;
                                height: 442px;
                                spacing: 6px;
                                Text {
                                    text: root.is-zh ? "\u{8c03}\u{8bd5}\u{6982}\u{89c8}" : "Debug Overview";
                                    height: 20px;
                                    color: #17252f;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 164px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 148px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "Host \u{8eab}\u{4efd}\u{4e0e}\u{8bbe}\u{5907}" : "Host Identity And Device";
                                        }
                                        StaticRow {
                                            x: 0px;
                                            y: 22px;
                                            name: root.is-zh ? "\u{8eab}\u{4efd}" : "Identity";
                                            value: root.identity-id;
                                            value-width: 374px;
                                            row-height: 18px;
                                            wrap-value: true;
                                            value-height: 32px;
                                        }
                                        StaticRow {
                                            x: 0px;
                                            y: 54px;
                                            name: root.is-zh ? "\u{8bbe}\u{5907}" : "Device";
                                            value: root.device-id;
                                            value-width: 374px;
                                            row-height: 18px;
                                            wrap-value: true;
                                            value-height: 32px;
                                        }
                                        LogPanel {
                                            x: 0px;
                                            y: 88px;
                                            width: 536px;
                                            panel-height: 54px;
                                            value: root.management-stats;
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 126px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 110px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{8fd0}\u{884c}\u{6458}\u{8981}" : "Runtime Summary";
                                        }
                                        LogPanel {
                                            x: 0px;
                                            y: 24px;
                                            width: 536px;
                                            panel-height: 78px;
                                            value: root.status-summary + "\n" + root.package-self-check;
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 124px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 108px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{8bca}\u{65ad}\u{5907}\u{6ce8}" : "Diagnostics Notes";
                                        }
                                        LogPanel {
                                            x: 0px;
                                            y: 24px;
                                            width: 536px;
                                            panel-height: 76px;
                                            value: root.diagnostics;
                                        }
                                    }
                                }
                            }

                            if root.active-page == 3: VerticalBox {
                                x: 18px;
                                y: 14px;
                                width: 564px;
                                height: 392px;
                                spacing: 6px;
                                Text {
                                    text: root.is-zh ? "\u{8fde}\u{63a5}\u{8054}\u{8c03}\u{6d4b}\u{8bd5}" : "Connection Tests";
                                    height: 20px;
                                    color: #17252f;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 110px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 94px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "Host \u{4e0e} Web \u{8054}\u{8c03}" : "Host And Web Tests";
                                        }
                                        HorizontalBox {
                                            x: 0px;
                                            y: 22px;
                                            width: 536px;
                                            height: 52px;
                                            spacing: 10px;
                                            Text {
                                                text: root.is-zh ? "\u{6700}\u{8fd1}\u{7ed3}\u{679c}" : "Latest Result";
                                                width: 150px;
                                                height: 52px;
                                                color: #62727d;
                                                font-size: 13px;
                                                vertical-alignment: top;
                                            }
                                            StatusBadge {
                                                label: root.connection-test-badge-label;
                                                tone: root.connection-test-badge-tone;
                                            }
                                            Rectangle {
                                                width: 264px;
                                                height: 52px;
                                                background: transparent;
                                            Text {
                                                text: root.connection-test-status;
                                                width: 264px;
                                                height: 52px;
                                                color: #17252f;
                                                font-size: 12px;
                                                vertical-alignment: top;
                                                wrap: word-wrap;
                                            }
                                            }
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 82px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 66px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{6267}\u{884c}\u{8054}\u{8c03}" : "Run Connection Tests";
                                        }
                                        HorizontalBox {
                                            x: 0px;
                                            y: 30px;
                                            width: 536px;
                                            height: 28px;
                                            spacing: 10px;
                                            ActionButton {
                                                label: root.connection-test-running
                                                    ? (root.is-zh ? "\u{6d4b}\u{8bd5}\u{4e2d}..." : "Testing...")
                                                    : (root.is-zh ? "\u{6d4b}\u{8bd5}\u{672c}\u{5730} Host" : "Test Local Host");
                                                primary: true;
                                                enabled: !root.connection-test-running;
                                                button-height: 28px;
                                                clicked => {
                                                    root.test-local-host();
                                                }
                                            }
                                            ActionButton {
                                                label: root.connection-test-running
                                                    ? (root.is-zh ? "\u{6d4b}\u{8bd5}\u{8fdc}\u{7a0b}\u{4e2d}..." : "Testing...")
                                                    : (root.is-zh ? "\u{6d4b}\u{8bd5}\u{8fdc}\u{7a0b} Web" : "Test Remote");
                                                primary: false;
                                                enabled: !root.connection-test-running;
                                                button-height: 28px;
                                                clicked => {
                                                    root.test-remote-connection();
                                                }
                                            }
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 142px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 126px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{8054}\u{8c03}\u{5907}\u{6ce8}\u{4e0e}\u{8fb9}\u{754c}" : "Diagnostics And Boundaries";
                                        }
                                        LogPanel {
                                            x: 0px;
                                            y: 24px;
                                            width: 536px;
                                            panel-height: 94px;
                                            value: root.diagnostics + "\n" + root.status-summary;
                                        }
                                    }
                                }
                            }

                            if root.active-page == 4: VerticalBox {
                                x: 18px;
                                y: 14px;
                                width: 564px;
                                height: 404px;
                                spacing: 6px;
                                Text {
                                    text: root.is-zh ? "\u{4e5d}\u{5bab}\u{683c}\u{6388}\u{6743}\u{6d4b}\u{8bd5}" : "Nine-Grid Tests";
                                    height: 20px;
                                    color: #17252f;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 112px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 96px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{4e5d}\u{5bab}\u{683c}\u{6388}\u{6743}\u{6d4b}\u{8bd5}" : "Nine-Grid Authorization Tests";
                                        }
                                        HorizontalBox {
                                            x: 0px;
                                            y: 22px;
                                            width: 536px;
                                            height: 56px;
                                            spacing: 10px;
                                            Text {
                                                text: root.is-zh ? "\u{6700}\u{8fd1}\u{7ed3}\u{679c}" : "Latest Result";
                                                width: 150px;
                                                height: 56px;
                                                color: #62727d;
                                                font-size: 13px;
                                                vertical-alignment: top;
                                            }
                                            StatusBadge {
                                                label: root.nine-grid-badge-label;
                                                tone: root.nine-grid-badge-tone;
                                            }
                                            Rectangle {
                                                width: 264px;
                                                height: 56px;
                                                background: transparent;
                                            Text {
                                                text: root.nine-grid-running
                                                    ? (root.is-zh ? "\u{6d4b}\u{8bd5}\u{4e2d}..." : "Testing...")
                                                    : root.nine-grid-status;
                                                width: 264px;
                                                height: 56px;
                                                color: #17252f;
                                                font-size: 12px;
                                                vertical-alignment: top;
                                                wrap: word-wrap;
                                            }
                                            }
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 82px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 66px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{6267}\u{884c}\u{6388}\u{6743}\u{6d4b}\u{8bd5}" : "Run Authorization Tests";
                                        }
                                        HorizontalBox {
                                            x: 0px;
                                            y: 30px;
                                            width: 536px;
                                            height: 28px;
                                            spacing: 8px;
                                            ActionButton {
                                                label: root.nine-grid-running
                                                    ? (root.is-zh ? "\u{6d4b}\u{8bd5}\u{4e2d}..." : "Testing...")
                                                    : (root.is-zh ? "6 \u{683c}\u{5bf9}\u{8c61}" : "6-cell Object");
                                                primary: true;
                                                enabled: !root.nine-grid-running;
                                                button-width: 128px;
                                                button-height: 28px;
                                                clicked => {
                                                    root.nine-grid-status = root.test-managed-object-nine-grid("normal");
                                                }
                                            }
                                            ActionButton {
                                                label: root.nine-grid-running
                                                    ? (root.is-zh ? "\u{6d4b}\u{8bd5}\u{4e2d}..." : "Testing...")
                                                    : (root.is-zh ? "12 \u{683c}\u{5bf9}\u{8c61}" : "12-cell Object");
                                                primary: false;
                                                enabled: !root.nine-grid-running;
                                                button-width: 128px;
                                                button-height: 28px;
                                                clicked => {
                                                    root.nine-grid-status = root.test-managed-object-nine-grid("confidential");
                                                }
                                            }
                                            ActionButton {
                                                label: root.nine-grid-running
                                                    ? (root.is-zh ? "\u{6d4b}\u{8bd5}\u{4e2d}..." : "Testing...")
                                                    : (root.is-zh ? "22 \u{683c}\u{5bf9}\u{8c61}" : "22-cell Object");
                                                primary: false;
                                                enabled: !root.nine-grid-running;
                                                button-width: 128px;
                                                button-height: 28px;
                                                clicked => {
                                                    root.nine-grid-status = root.test-managed-object-nine-grid("top-secret");
                                                }
                                            }
                                        }
                                    }
                                }
                                SectionPanel {
                                    panel-width: 564px;
                                    panel-height: 142px;
                                    Rectangle {
                                        x: 14px;
                                        y: 8px;
                                        width: 536px;
                                        height: 126px;
                                        background: transparent;
                                        SectionTitle {
                                            x: 0px;
                                            y: 0px;
                                            width: 536px;
                                            label: root.is-zh ? "\u{6388}\u{6743}\u{8fb9}\u{754c}\u{4e0e}\u{5305}\u{81ea}\u{68c0}" : "Authorization Boundaries";
                                        }
                                        LogPanel {
                                            x: 0px;
                                            y: 24px;
                                            width: 536px;
                                            panel-height: 94px;
                                            value: root.management-stats + "\n" + root.package-self-check;
                                        }
                                    }
                                }
                            }
                            }
                        }
                    }
                }
            }
        }
    }


export component SettingsDialog inherits Window {
        in-out property <string> language: "zh";
        in-out property <string> host-config-file: "";
        property <bool> is-zh: language == "zh";
        callback close-requested();
        callback language-changed(string);
        callback browse-host-config-file();

        title: is-zh ? "\u{8bbe}\u{7f6e}" : "Settings";
        preferred-width: 760px;
        preferred-height: 300px;
        background: #eef3f5;

        VerticalBox {
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 24px;
            padding-bottom: 24px;
            spacing: 14px;
            Rectangle {
                height: 36px;
                background: transparent;
                Text {
                    x: 0px;
                    y: 4px;
                    width: 400px;
                    height: 28px;
                    text: is-zh ? "\u{8bbe}\u{7f6e}" : "Settings";
                    font-size: 16px;
                    font-weight: 800;
                    color: #17252f;
                    overflow: elide;
                }
            }
            SectionPanel {
                panel-width: 712px;
                panel-height: 82px;
                Rectangle {
                    x: 14px;
                    y: 11px;
                    width: 684px;
                    height: 60px;
                    background: transparent;
                    SectionTitle {
                        x: 0px;
                        y: 0px;
                        width: 684px;
                        label: is-zh ? "\u{901a}\u{7528}\u{8bbe}\u{7f6e}" : "General";
                    }
                    HorizontalBox {
                        x: 0px;
                        y: 24px;
                        width: 684px;
                        height: 32px;
                        spacing: 14px;
                        Text {
                            text: is-zh ? "\u{754c}\u{9762}\u{8bed}\u{8a00}" : "UI Language";
                            width: 150px;
                            height: 32px;
                            color: #62727d;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        ComboBox {
                            width: 294px;
                            height: 32px;
                            model: ["\u{4e2d}\u{6587}", "English"];
                            current-value: is-zh ? "\u{4e2d}\u{6587}" : "English";
                            selected(value) => {
                                root.language = value == "\u{4e2d}\u{6587}" ? "zh" : "en";
                                root.language-changed(value == "\u{4e2d}\u{6587}" ? "zh" : "en");
                            }
                        }
                    }
                }
            }
            SectionPanel {
                panel-width: 712px;
                panel-height: 84px;
                Rectangle {
                    x: 14px;
                    y: 12px;
                    width: 684px;
                    height: 60px;
                    background: transparent;
                    SectionTitle {
                        x: 0px;
                        y: 0px;
                        width: 684px;
                        label: is-zh ? "\u{914d}\u{7f6e}\u{6587}\u{4ef6}" : "Config File";
                    }
                    PathBrowseRow {
                        x: 0px;
                        y: 24px;
                        width: 684px;
                        height: 32px;
                        name: is-zh ? "Host \u{914d}\u{7f6e}\u{6587}\u{4ef6}" : "Host Config File";
                        value <=> root.host-config-file;
                        is-zh: root.is-zh;
                        editor-width: 452px;
                        row-height: 32px;
                        read-only: true;
                        browse => { root.browse-host-config-file(); }
                    }
                }
            }
        }
    }

export component StoryLockAuthorizationDialog inherits Window {
        in property <bool> is-zh: true;
        in property <int> challenge-count: 22;
        in-out property <int> current-index: 0;
        in property <bool> can-previous: current-index > 0;
        in property <bool> can-next: current-index + 1 < challenge-count;
        in property <string> current-position: "1/22";
        in property <string> current-prompt: "";
        in property <string> selected-answer: "";
        in property <string> option-1: "";
        in property <string> option-2: "";
        in property <string> option-3: "";
        in property <string> option-4: "";
        in property <string> option-5: "";
        in property <string> option-6: "";
        in property <string> option-7: "";
        in property <string> option-8: "";
        in property <string> option-9: "";
        in-out property <string> option-1-state: "wrong";
        in-out property <string> option-2-state: "wrong";
        in-out property <string> option-3-state: "wrong";
        in-out property <string> option-4-state: "wrong";
        in-out property <string> option-5-state: "wrong";
        in-out property <string> option-6-state: "wrong";
        in-out property <string> option-7-state: "wrong";
        in-out property <string> option-8-state: "wrong";
        in-out property <string> option-9-state: "wrong";
        callback select-answer(int);
        callback previous-requested();
        callback next-requested();
        callback authorize-requested();
        callback cancel-requested();

        title: root.is-zh ? "StoryLock \u{4e5d}\u{5bab}\u{683c}\u{6311}\u{6218}" : "StoryLock Grid Challenge";
        preferred-width: 960px;
        preferred-height: 540px;
        min-width: 960px;
        max-width: 960px;
        min-height: 540px;
        max-height: 540px;
        background: #eef3f5;

        VerticalBox {
            padding: 20px;
            spacing: 10px;
            Text {
                text: root.is-zh ? "\u{8bf7}\u{4ece}\u{4e5d}\u{5bab}\u{683c}\u{4e2d}\u{9009}\u{62e9}\u{6bcf}\u{9898}\u{7684}\u{7b54}\u{6848}\u{3002}" : "Select the answer for each grid challenge.";
                height: 28px;
                font-size: 16px;
                font-weight: 800;
                color: #17252f;
                overflow: elide;
            }
            Rectangle {
                width: 920px;
                height: 66px;
                border-radius: 6px;
                border-width: 1px;
                border-color: #c9d5da;
                background: #f7fafb;
                Text {
                    x: 14px;
                    y: 8px;
                    width: 892px;
                    height: 14px;
                    text: root.current-position;
                    color: #62727d;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    x: 14px;
                    y: 26px;
                    width: 892px;
                    height: 32px;
                    text: root.current-prompt;
                    color: #17252f;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: top;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }
            HorizontalBox {
                width: 920px;
                height: 326px;
                spacing: 16px;

                LearningAnswerGrid {
                    answer-1: root.option-1;
                    answer-1-state <=> root.option-1-state;
                    answer-2: root.option-2;
                    answer-2-state <=> root.option-2-state;
                    answer-3: root.option-3;
                    answer-3-state <=> root.option-3-state;
                    answer-4: root.option-4;
                    answer-4-state <=> root.option-4-state;
                    answer-5: root.option-5;
                    answer-5-state <=> root.option-5-state;
                    answer-6: root.option-6;
                    answer-6-state <=> root.option-6-state;
                    answer-7: root.option-7;
                    answer-7-state <=> root.option-7-state;
                    answer-8: root.option-8;
                    answer-8-state <=> root.option-8-state;
                    answer-9: root.option-9;
                    answer-9-state <=> root.option-9-state;
                    toggle-answer(index) => { root.select-answer(index); }
                }
                Rectangle {
                    width: 180px;
                    height: 150px;
                    border-width: 1px;
                    border-color: #d7e1e6;
                    border-radius: 6px;
                    background: #f7fafb;
                    Text {
                        x: 0px;
                        y: 8px;
                        width: parent.width;
                        height: 18px;
                        text: root.current-position;
                        color: #17252f;
                        font-size: 16px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    HorizontalBox {
                        x: 12px;
                        y: 38px;
                        width: 156px;
                        height: 34px;
                        spacing: 8px;
                        ActionButton { label: root.is-zh ? "\u{4e0a}\u{9898}" : "Prev"; primary: false; enabled: root.can-previous; button-width: 74px; clicked => { root.previous-requested(); } }
                        ActionButton { label: root.is-zh ? "\u{4e0b}\u{9898}" : "Next"; primary: false; enabled: root.can-next; button-width: 74px; clicked => { root.next-requested(); } }
                    }
                    Rectangle { x: 20px; y: 84px; width: 140px; height: 1px; background: #d7e1e6; }
                    HorizontalBox {
                        x: 12px;
                        y: 98px;
                        width: 156px;
                        height: 34px;
                        spacing: 8px;
                        ActionButton { label: root.is-zh ? "\u{6388}\u{6743}" : "Authorize"; primary: true; button-width: 92px; clicked => { root.authorize-requested(); } }
                        ActionButton { label: root.is-zh ? "\u{53d6}\u{6d88}" : "Cancel"; primary: false; danger: true; button-width: 56px; clicked => { root.cancel-requested(); } }
                    }
                }
            }
        }
}

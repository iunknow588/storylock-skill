import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { StaticRow, EditableRow, ActionButton, StaticTextPanel, CopyableLogPanel, SectionPanel, SectionTitle } from "../common.slint";

export component LearningPage inherits Rectangle {
    in property <bool> is-zh;
    in property <int> mode: 0;
    in-out property <string> pre-learning-prompts-per-question;
    in-out property <string> pre-learning-error-tolerance;
    in-out property <string> weak-item-limit;
    in-out property <string> initial-days;
    in-out property <string> initial-frequency-days;
    in-out property <string> consolidation-days;
    in-out property <string> consolidation-frequency-days;
    in-out property <string> adaptation-weeks;
    in-out property <string> adaptation-frequency-weeks;
    in-out property <string> stable-months;
    in-out property <string> stable-frequency-months;
    in-out property <string> long-term-years;
    in-out property <string> long-term-frequency-years;
    in property <string> learning-plan-summary;
    in property <string> learning-status;
    in property <string> learning-progress-summary;
    in property <int> learning-progress-percent: 0;
    in property <string> learning-progress-headline;
    callback save-learning-policy();

    x: 0px;
    y: 0px;
    width: 720px;
    height: 374px;

    if root.mode == 0: VerticalBox {
        x: 12px;
        y: 12px;
        width: 696px;
        height: 350px;
        spacing: 8px;
        SectionPanel {
            panel-width: 696px;
            panel-height: 192px;
            VerticalBox {
                x: 14px;
                y: 10px;
                width: 668px;
                height: 172px;
                spacing: 8px;
                SectionTitle { label: root.is-zh ? "\u{9884}\u{5b66}\u{4e60}\u{53c2}\u{6570}" : "Pre-Learning Parameters"; }
                StaticRow { name: root.is-zh ? "\u{8bad}\u{7ec3}\u{53c2}\u{6570}\u{6587}\u{4ef6}" : "Learning File"; value: "learning-policy.json"; value-width: 504px; row-height: 26px; }
                EditableRow { name: root.is-zh ? "\u{6bcf}\u{9898}\u{8bad}\u{7ec3}\u{6b21}\u{6570}" : "Prompts Per Q"; value <=> root.pre-learning-prompts-per-question; editor-width: 504px; row-height: 28px; }
                EditableRow { name: root.is-zh ? "\u{9519}\u{8bef}\u{4e0a}\u{9650}" : "Error Max"; value <=> root.pre-learning-error-tolerance; editor-width: 504px; row-height: 28px; }
                EditableRow { name: root.is-zh ? "\u{5f31}\u{9879}\u{4e0a}\u{9650}" : "Weak Item Max"; value <=> root.weak-item-limit; editor-width: 504px; row-height: 28px; }
            }
        }
        SectionPanel {
            panel-width: 696px;
            panel-height: 144px;
            VerticalBox {
                x: 14px;
                y: 10px;
                width: 668px;
                height: 124px;
                spacing: 6px;
                SectionTitle { label: root.is-zh ? "\u{72b6}\u{6001}" : "Status"; }
                StaticRow { name: root.is-zh ? "\u{8bad}\u{7ec3}\u{6458}\u{8981}" : "Training Summary"; value: root.learning-plan-summary; value-width: 504px; row-height: 22px; }
                StaticRow { name: root.is-zh ? "\u{5f53}\u{524d}\u{72b6}\u{6001}" : "Status"; value: root.learning-status; value-width: 504px; row-height: 22px; }
                Text {
                    text: root.learning-progress-headline;
                    height: 28px;
                    color: #5a6b75;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Rectangle {
                    width: 668px;
                    height: 10px;
                    border-radius: 5px;
                    background: #dfe7eb;
                    Rectangle {
                        width: parent.width * root.learning-progress-percent / 100;
                        height: 10px;
                        border-radius: 5px;
                        background: #7fb38d;
                    }
                }
                Text {
                    text: (root.is-zh ? "\u{8bad}\u{7ec3}\u{8fdb}\u{5ea6}: " : "Progress: ") + root.learning-progress-summary;
                    height: 28px;
                    color: #17252f;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
        HorizontalBox {
            spacing: 10px;
            Rectangle { width: 180px; height: 1px; background: transparent; }
            ActionButton { label: root.is-zh ? "\u{4fdd}\u{5b58}\u{53c2}\u{6570}" : "Save Settings"; primary: true; button-height: 30px; clicked => { root.save-learning-policy(); } }
        }
    }

    if root.mode == 1: VerticalBox {
        x: 12px;
        y: 12px;
        width: 696px;
        height: 350px;
        spacing: 8px;
        SectionPanel {
            panel-width: 696px;
            panel-height: 242px;
            VerticalBox {
                x: 14px;
                y: 10px;
                width: 668px;
                height: 222px;
                spacing: 5px;
                SectionTitle { label: root.is-zh ? "\u{7559}\u{5b58}\u{5b66}\u{4e60}\u{8282}\u{594f}" : "Retention Schedule"; }
                HorizontalBox {
                    spacing: 12px;
                    VerticalBox {
                        width: 328px;
                        height: 188px;
                        spacing: 5px;
                        EditableRow { name: root.is-zh ? "\u{521d}\u{59cb}\u{5929}\u{6570}" : "Initial Days"; value <=> root.initial-days; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{521d}\u{59cb}\u{9891}\u{7387}" : "Initial Freq"; value <=> root.initial-frequency-days; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{5de9}\u{56fa}\u{5929}\u{6570}" : "Consolid. Days"; value <=> root.consolidation-days; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{5de9}\u{56fa}\u{9891}\u{7387}" : "Consolid. Freq"; value <=> root.consolidation-frequency-days; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{9002}\u{5e94}\u{5468}\u{6570}" : "Adapt Weeks"; value <=> root.adaptation-weeks; editor-width: 164px; row-height: 26px; }
                    }
                    VerticalBox {
                        width: 328px;
                        height: 188px;
                        spacing: 5px;
                        EditableRow { name: root.is-zh ? "\u{9002}\u{5e94}\u{9891}\u{7387}" : "Adapt Freq"; value <=> root.adaptation-frequency-weeks; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{7a33}\u{5b9a}\u{6708}\u{6570}" : "Stable Months"; value <=> root.stable-months; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{7a33}\u{5b9a}\u{9891}\u{7387}" : "Stable Freq"; value <=> root.stable-frequency-months; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{957f}\u{671f}\u{5e74}\u{6570}" : "Long Years"; value <=> root.long-term-years; editor-width: 164px; row-height: 26px; }
                        EditableRow { name: root.is-zh ? "\u{957f}\u{671f}\u{9891}\u{7387}" : "Long Freq"; value <=> root.long-term-frequency-years; editor-width: 164px; row-height: 26px; }
                    }
                }
            }
        }
        SectionPanel {
            panel-width: 696px;
            panel-height: 116px;
            VerticalBox {
                x: 14px;
                y: 10px;
                width: 668px;
                height: 96px;
                spacing: 6px;
                StaticRow {
                    name: root.is-zh ? "\u{5f53}\u{524d}\u{72b6}\u{6001}" : "Status";
                    value: root.learning-status;
                    value-width: 504px;
                    row-height: 22px;
                }
                Text {
                    text: root.learning-progress-headline;
                    height: 28px;
                    color: #5a6b75;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Rectangle {
                    width: 668px;
                    height: 10px;
                    border-radius: 5px;
                    background: #dfe7eb;
                    Rectangle {
                        width: parent.width * root.learning-progress-percent / 100;
                        height: 10px;
                        border-radius: 5px;
                        background: #7fb38d;
                    }
                }
                Text {
                    text: (root.is-zh ? "\u{8bad}\u{7ec3}\u{8fdb}\u{5ea6}: " : "Progress: ") + root.learning-progress-summary;
                    height: 28px;
                    color: #17252f;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
        HorizontalBox {
            spacing: 10px;
            Rectangle { width: 180px; height: 1px; background: transparent; }
            ActionButton { label: root.is-zh ? "\u{4fdd}\u{5b58}\u{8282}\u{594f}" : "Save Schedule"; primary: true; button-height: 30px; clicked => { root.save-learning-policy(); } }
        }
    }
}

export component ExportPage inherits VerticalBox {
    in property <bool> is-zh;
    in property <string> learning-plan-summary;
    in property <string> learning-status;
    in property <string> learning-progress-summary;
    in property <int> learning-progress-percent: 0;
    in property <string> learning-progress-headline;
    in property <string> learning-action-hint;
    in property <string> learning-result;
    in property <string> config-status;
    in property <bool> export-ready;
    callback run-learning();
    callback export-package();

    x: 0px;
    y: 0px;
    width: 720px;
    height: 374px;
    spacing: 12px;

    VerticalBox {
        x: 12px;
        width: 696px;
        spacing: 8px;
        SectionPanel {
            panel-width: 696px;
            panel-height: 156px;
            VerticalBox {
                x: 14px;
                y: 10px;
                width: 668px;
                height: 136px;
                spacing: 6px;
                SectionTitle { label: root.is-zh ? "\u{5b66}\u{4e60}\u{95e8}\u{7981}" : "Learning Gate"; }
                StaticTextPanel {
                    width: 668px;
                    panel-height: 44px;
                    value: (root.is-zh ? "\u{8bad}\u{7ec3}\u{89c4}\u{5219}: " : "Rule: ")
                        + root.learning-plan-summary
                        + "\n"
                        + (root.is-zh ? "\u{8bad}\u{7ec3}\u{72b6}\u{6001}: " : "Status: ")
                        + root.learning-status;
                }
                Text {
                    text: root.learning-progress-headline;
                    height: 28px;
                    color: #5a6b75;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Rectangle {
                    width: 668px;
                    height: 10px;
                    border-radius: 5px;
                    background: #dfe7eb;
                    Rectangle {
                        width: parent.width * root.learning-progress-percent / 100;
                        height: 10px;
                        border-radius: 5px;
                        background: #7fb38d;
                    }
                }
                Text {
                    text: (root.is-zh ? "\u{8bad}\u{7ec3}\u{8fdb}\u{5ea6}: " : "Progress: ") + root.learning-progress-summary;
                    height: 28px;
                    color: #17252f;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
        HorizontalBox {
            spacing: 10px;
            Rectangle { width: 164px; height: 1px; background: transparent; }
            ActionButton { label: root.is-zh ? "\u{5f00}\u{59cb}\u{6d4b}\u{8bd5}" : "Start Test"; primary: true; enabled: true; button-height: 30px; clicked => { root.run-learning(); } }
            ActionButton { label: root.export-ready ? (root.is-zh ? "\u{5bfc}\u{51fa}" : "Export") : (root.is-zh ? "\u{672a}\u{6d4b}\u{8bd5}\u{ff0c}\u{4e0d}\u{53ef}\u{5bfc}\u{51fa}" : "Export Locked"); primary: root.export-ready; enabled: root.export-ready; button-width: 170px; button-height: 30px; clicked => { root.export-package(); } }
        }
        CopyableLogPanel {
            width: 696px;
            panel-height: 170px;
            value: (root.is-zh ? "\u{6d4b}\u{8bd5}\u{72b6}\u{6001}: " : "Test Status: ")
                + root.learning-result
                + "\n\n"
                + (root.is-zh ? "\u{5bfc}\u{51fa}\u{72b6}\u{6001}: " : "Export Status: ")
                + root.config-status;
        }
    }
}

import { VerticalBox, HorizontalBox, ComboBox, LineEdit } from "std-widgets.slint";
import { PathBrowseRow, StaticRow, ActionButton, QuestionConfigPanel, LearningAnswerGrid, LogPanel } from "../common.slint";

export component StoryLockCoreSettingsDialog inherits Window {
    in-out property <string> language: "zh";
    property <bool> is-zh: language == "zh";
    in-out property <string> core-data-dir: "";
    callback close-requested();
    callback language-changed(string);
    callback browse-core-data-dir();

    title: root.is-zh ? "StoryLock Core 设置" : "StoryLock Core Settings";
    preferred-width: 800px;
    preferred-height: 450px;
    min-width: 800px;
    max-width: 800px;
    min-height: 450px;
    max-height: 450px;
    background: #eef3f5;

    VerticalBox {
        padding: 20px;
        spacing: 12px;
        Rectangle {
            height: 36px;
            background: transparent;
            Text {
                x: 0px;
                y: 4px;
                width: 720px;
                height: 28px;
                text: root.is-zh ? "StoryLock Core 设置" : "StoryLock Core Settings";
                color: #17252f;
                font-size: 16px;
                font-weight: 800;
                overflow: elide;
            }
        }
        VerticalBox {
            spacing: 14px;
            HorizontalBox {
                spacing: 14px;
                Text {
                    text: root.is-zh ? "界面语言" : "UI Language";
                    width: 150px;
                    color: #62727d;
                    font-size: 13px;
                    vertical-alignment: center;
                }
                ComboBox {
                    width: 420px;
                    height: 32px;
                    model: root.is-zh ? ["中文", "英文"] : ["Chinese", "English"];
                    current-value: root.is-zh ? "中文" : "English";
                    selected(value) => {
                        root.language = (value == "Chinese" || value == "中文") ? "zh" : "en";
                        root.language-changed(root.language);
                    }
                }
            }
            PathBrowseRow {
                name: root.is-zh ? "工作目录" : "Workspace Dir";
                value <=> root.core-data-dir;
                is-zh: root.is-zh;
                browse => { root.browse-core-data-dir(); }
            }
            StaticRow { name: root.is-zh ? "保险库文件" : "Vault File"; value: "vault.stlk"; }
            StaticRow { name: root.is-zh ? "学习参数文件" : "Learning Policy"; value: "learning-policy.json"; }
            StaticRow { name: root.is-zh ? "清单文件" : "Package Manifest"; value: "package-manifest.json"; }
            StaticRow { name: root.is-zh ? "资源目录文件" : "Resource Catalog"; value: "resource-catalog.json"; }
        }
    }
}

export component AnswerEditorDialog inherits Window {
    in-out property <string> language: "zh";
    property <bool> is-zh: language == "zh";
    in-out property <string> selected-question: "1";
    in-out property <string> question-text: "";
    in-out property <string> answer-1: "";
    in-out property <string> answer-1-state: "wrong";
    in-out property <string> answer-2: "";
    in-out property <string> answer-2-state: "wrong";
    in-out property <string> answer-3: "";
    in-out property <string> answer-3-state: "wrong";
    in-out property <string> answer-4: "";
    in-out property <string> answer-4-state: "wrong";
    in-out property <string> answer-5: "";
    in-out property <string> answer-5-state: "wrong";
    in-out property <string> answer-6: "";
    in-out property <string> answer-6-state: "wrong";
    in-out property <string> answer-7: "";
    in-out property <string> answer-7-state: "wrong";
    in-out property <string> answer-8: "";
    in-out property <string> answer-8-state: "wrong";
    in-out property <string> answer-9: "";
    in-out property <string> answer-9-state: "wrong";
    callback previous-node();
    callback next-node();
    callback select-node(string);

    title: root.is-zh ? "答案编辑" : "Answer Editor";
    preferred-width: 960px;
    preferred-height: 540px;
    min-width: 960px;
    max-width: 960px;
    min-height: 540px;
    max-height: 540px;
    background: #eef3f5;

    VerticalBox {
        padding: 20px;
        spacing: 12px;
        Rectangle {
            height: 36px;
            background: transparent;
            Text {
                x: 0px;
                y: 4px;
                width: 900px;
                height: 28px;
                text: (root.is-zh ? "答案编辑 - " : "Answer Editor - ") + root.selected-question;
                color: #17252f;
                font-size: 16px;
                font-weight: 800;
                overflow: elide;
            }
        }
        QuestionConfigPanel {
            panel-height: 422px;
            selected-question <=> root.selected-question;
            question-text <=> root.question-text;
            answer-1 <=> root.answer-1;
            answer-1-state <=> root.answer-1-state;
            answer-2 <=> root.answer-2;
            answer-2-state <=> root.answer-2-state;
            answer-3 <=> root.answer-3;
            answer-3-state <=> root.answer-3-state;
            answer-4 <=> root.answer-4;
            answer-4-state <=> root.answer-4-state;
            answer-5 <=> root.answer-5;
            answer-5-state <=> root.answer-5-state;
            answer-6 <=> root.answer-6;
            answer-6-state <=> root.answer-6-state;
            answer-7 <=> root.answer-7;
            answer-7-state <=> root.answer-7-state;
            answer-8 <=> root.answer-8;
            answer-8-state <=> root.answer-8-state;
            answer-9 <=> root.answer-9;
            answer-9-state <=> root.answer-9-state;
            previous-node => { root.previous-node(); }
            next-node => { root.next-node(); }
            select-node(value) => { root.select-node(value); }
        }
    }
}

export component ObjectEditorDialog inherits Window {
    in-out property <string> language: "zh";
    property <bool> is-zh: language == "zh";
    in-out property <string> uri: "";
    in-out property <string> username: "";
    in-out property <string> password: "";
    in-out property <bool> show-password: false;
    callback save-requested();
    callback close-requested();

    title: root.is-zh ? "受保护对象编辑" : "Managed Object Editor";
    preferred-width: 760px;
    preferred-height: 300px;
    min-width: 760px;
    max-width: 760px;
    min-height: 300px;
    max-height: 300px;
    background: #eef3f5;

    VerticalBox {
        padding: 20px;
        spacing: 12px;
        Text {
            height: 28px;
            text: root.is-zh ? "受保护对象编辑" : "Managed Object Editor";
            color: #17252f;
            font-size: 16px;
            font-weight: 800;
            overflow: elide;
        }
        HorizontalBox {
            spacing: 14px;
            Text {
                text: "URI";
                width: 150px;
                color: #62727d;
                font-size: 13px;
                vertical-alignment: center;
            }
            LineEdit {
                text: root.uri;
                width: 556px;
                height: 32px;
                edited(value) => {
                    root.uri = value;
                }
            }
        }
        HorizontalBox {
            spacing: 14px;
            Text {
                text: root.is-zh ? "用户名" : "Username";
                width: 150px;
                color: #62727d;
                font-size: 13px;
                vertical-alignment: center;
            }
            LineEdit {
                text: root.username;
                width: 556px;
                height: 32px;
                edited(value) => {
                    root.username = value;
                }
            }
        }
        HorizontalBox {
            spacing: 14px;
            Text {
                text: root.is-zh ? "密码" : "Password";
                width: 150px;
                color: #62727d;
                font-size: 13px;
                vertical-alignment: center;
            }
            LineEdit {
                text: root.password;
                width: 420px;
                height: 32px;
                input-type: root.show-password ? InputType.text : InputType.password;
                edited(value) => {
                    root.password = value;
                }
            }
            ActionButton {
                label: root.show-password ? (root.is-zh ? "隐藏" : "Hide") : (root.is-zh ? "显示" : "Show");
                primary: false;
                button-width: 86px;
                clicked => {
                    root.show-password = !root.show-password;
                }
            }
        }
        HorizontalBox {
            spacing: 10px;
            Rectangle { width: 164px; height: 1px; background: transparent; }
            ActionButton {
                label: root.is-zh ? "保存" : "Save";
                primary: true;
                clicked => { root.save-requested(); }
            }
            ActionButton {
                label: root.is-zh ? "关闭" : "Close";
                primary: false;
                clicked => { root.close-requested(); }
            }
        }
    }
}

export component LearningTestDialog inherits Dialog {
    in-out property <string> language: "zh";
    property <bool> is-zh: language == "zh";
    in property <string> learning-plan-summary;
    in property <string> learning-status;
    in property <string> learning-progress-summary;
    in property <string> learning-action-hint;
    in property <string> learning-position;
    in property <string> learning-question;
    in-out property <string> learning-answer-1;
    in-out property <string> learning-answer-1-state;
    in-out property <string> learning-answer-2;
    in-out property <string> learning-answer-2-state;
    in-out property <string> learning-answer-3;
    in-out property <string> learning-answer-3-state;
    in-out property <string> learning-answer-4;
    in-out property <string> learning-answer-4-state;
    in-out property <string> learning-answer-5;
    in-out property <string> learning-answer-5-state;
    in-out property <string> learning-answer-6;
    in-out property <string> learning-answer-6-state;
    in-out property <string> learning-answer-7;
    in-out property <string> learning-answer-7-state;
    in-out property <string> learning-answer-8;
    in-out property <string> learning-answer-8-state;
    in-out property <string> learning-answer-9;
    in-out property <string> learning-answer-9-state;
    in property <string> learning-result;
    callback restart-learning();
    callback reveal-learning-answer();
    callback learning-previous();
    callback learning-next();
    callback check-learning-current();
    callback close-requested();

    title: root.is-zh ? "九宫格学习测试" : "Nine-Grid Learning Test";
    preferred-width: 860px;
    preferred-height: 760px;
    min-width: 860px;
    max-width: 860px;
    min-height: 760px;
    max-height: 760px;
    background: #eef3f5;

    Rectangle {
        background: #eef3f5;
        VerticalBox {
            padding: 20px;
            spacing: 12px;
            Text {
                height: 28px;
                text: root.is-zh ? "九宫格学习测试" : "Nine-Grid Learning Test";
                color: #17252f;
                font-size: 16px;
                font-weight: 800;
                overflow: elide;
            }
            StaticRow { name: root.is-zh ? "训练规则" : "Training Rule"; value: root.learning-plan-summary; }
            StaticRow { name: root.is-zh ? "训练状态" : "Training Status"; value: root.learning-status; }
            StaticRow { name: root.is-zh ? "当前进度" : "Progress"; value: root.learning-progress-summary; }
            StaticRow { name: root.is-zh ? "下一步" : "Next Step"; value: root.learning-action-hint; }
            StaticRow { name: root.is-zh ? "当前题目" : "Current Question"; value: root.learning-position + "  " + root.learning-question; }
            LearningAnswerGrid {
                answer-1: root.learning-answer-1;
                answer-1-state <=> root.learning-answer-1-state;
                answer-2: root.learning-answer-2;
                answer-2-state <=> root.learning-answer-2-state;
                answer-3: root.learning-answer-3;
                answer-3-state <=> root.learning-answer-3-state;
                answer-4: root.learning-answer-4;
                answer-4-state <=> root.learning-answer-4-state;
                answer-5: root.learning-answer-5;
                answer-5-state <=> root.learning-answer-5-state;
                answer-6: root.learning-answer-6;
                answer-6-state <=> root.learning-answer-6-state;
                answer-7: root.learning-answer-7;
                answer-7-state <=> root.learning-answer-7-state;
                answer-8: root.learning-answer-8;
                answer-8-state <=> root.learning-answer-8-state;
                answer-9: root.learning-answer-9;
                answer-9-state <=> root.learning-answer-9-state;
            }
            HorizontalBox {
                spacing: 10px;
                ActionButton { label: root.is-zh ? "重新开始" : "Restart"; primary: true; button-width: 110px; clicked => { root.restart-learning(); } }
                ActionButton { label: root.is-zh ? "显示答案" : "Reveal"; primary: false; button-width: 110px; clicked => { root.reveal-learning-answer(); } }
                ActionButton { label: root.is-zh ? "上一题" : "Previous"; primary: false; button-width: 110px; clicked => { root.learning-previous(); } }
                ActionButton { label: root.is-zh ? "下一题" : "Next"; primary: false; button-width: 110px; clicked => { root.learning-next(); } }
                ActionButton { label: root.is-zh ? "检查" : "Check"; primary: true; button-width: 110px; clicked => { root.check-learning-current(); } }
                ActionButton { label: root.is-zh ? "关闭" : "Close"; primary: false; button-width: 110px; clicked => { root.close-requested(); } }
            }
            LogPanel { value: root.learning-result; panel-height: 120px; }
        }
    }
}

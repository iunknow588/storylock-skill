{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocalAuthorizationSelftestReport",
  "type": "object",
  "required": ["package", "status", "checks"],
  "properties": {
    "package": {
      "type": "string",
      "const": "storylock-local-story-access-skill"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

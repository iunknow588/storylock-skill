{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryReadInput",
  "type": "object",
  "required": ["identityId", "storyObjectId"],
  "properties": {
    "identityId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "storyObjectId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "answers": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "maxLength": 512
          },
          {
            "type": "object",
            "required": ["answer"],
            "properties": {
              "answer": {
                "type": "string",
                "maxLength": 512
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "nonce": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "expiry": {
      "type": "number"
    },
    "redactionLevel": {
      "type": "string",
      "enum": ["none", "partial", "full"],
      "default": "partial"
    },
    "policyHints": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "additionalProperties": false
}

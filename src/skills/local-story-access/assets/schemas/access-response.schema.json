{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocalAuthorizationResponse",
  "type": "object",
  "required": [
    "requestId",
    "status",
    "capability",
    "executionLocation",
    "result",
    "redactionLevel",
    "retentionGranted",
    "auditMeta",
    "error"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "capability": {
      "type": "string",
      "enum": [
        "resolveObjectStrength",
        "createGridVerification",
        "authorizeLocalAction",
        "revokeLocalAuthorization"
      ]
    },
    "executionLocation": {
      "type": "string",
      "const": "local"
    },
    "result": {},
    "redactionLevel": {
      "type": "string",
      "enum": ["none", "partial", "full"]
    },
    "retentionGranted": {
      "type": "string",
      "enum": ["none", "result_only", "audit_meta_only"]
    },
    "auditMeta": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["code", "type", "message", "suggestedAction", "retryable"],
          "properties": {
            "code": {
              "type": "string",
              "pattern": "^SLG-[0-9]{3}$"
            },
            "type": {
              "type": "string",
              "minLength": 1
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "suggestedAction": {
              "type": "string",
              "minLength": 1
            },
            "retryable": {
              "type": "boolean"
            },
            "retryAfter": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}

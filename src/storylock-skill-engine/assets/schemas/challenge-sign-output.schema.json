{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChallengeSigningAuthorizationOutput",
  "type": "object",
  "required": [
    "mode",
    "challenge",
    "authorization",
    "keyId",
    "algorithm",
    "payload",
    "scope",
    "secretReference",
    "signature",
    "attachments"
  ],
  "properties": {
    "mode": { "const": "challenge_signing_authorization" },
    "challenge": { "type": "object" },
    "authorization": { "type": "object" },
    "keyId": { "type": "string" },
    "algorithm": { "type": "string" },
    "payload": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 255 }
        }
      ]
    },
    "scope": { "type": "string" },
    "secretReference": { "type": "string" },
    "signature": {},
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attachmentId", "secretReference"],
        "properties": {
          "attachmentId": { "type": "string" },
          "secretReference": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

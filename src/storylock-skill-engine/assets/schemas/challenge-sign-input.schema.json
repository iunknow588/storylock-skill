{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChallengeSignInput",
  "type": "object",
  "required": ["identityId", "keyId", "algorithm", "payload"],
  "properties": {
    "identityId": { "type": "string", "minLength": 1 },
    "keyId": { "type": "string", "minLength": 1 },
    "algorithm": { "type": "string", "minLength": 1 },
    "payload": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 255 }
        }
      ]
    },
    "secretObjectId": { "type": "string" },
    "resourceId": { "type": ["string", "null"] },
    "primaryRole": { "type": ["string", "null"] },
    "resourceCatalog": { "type": ["object", "null"] },
    "includeKeyMaterial": { "type": "boolean" },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "attachmentId": { "type": "string" },
          "includeMaterial": { "type": "boolean" },
          "resourceId": { "type": "string" },
          "role": { "type": "string" },
          "secretObjectId": { "type": "string" }
        },
        "required": ["attachmentId"],
        "additionalProperties": true
      }
    },
    "answers": {
      "type": "array"
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocalPasswordFillInput",
  "type": "object",
  "required": ["identityId", "siteId"],
  "properties": {
    "identityId": { "type": "string", "minLength": 1 },
    "siteId": { "type": "string", "minLength": 1 },
    "resourceId": { "type": ["string", "null"] },
    "resourceCatalog": { "type": ["object", "null"] },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fieldName": { "type": "string" },
          "role": { "type": "string" },
          "resourceId": { "type": "string" },
          "secretObjectId": { "type": "string" },
          "objectId": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "bindingMode": {
      "type": "string",
      "enum": ["manual_only", "template_only", "template_with_overrides"]
    },
    "answers": {
      "type": "array"
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryLockAuthorDraft",
  "type": "object",
  "required": ["storyTitle", "nodes"],
  "properties": {
    "version": { "type": "string" },
    "storyTitle": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "memoryAnchors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "elementGroups": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nodes": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": {
        "$ref": "storylock-node.schema.json"
      }
    }
  },
  "additionalProperties": false
}

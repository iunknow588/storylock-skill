{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryLockResourceCatalog",
  "type": "object",
  "required": ["resources"],
  "properties": {
    "version": { "type": "string" },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resourceId", "resourceKind", "providerId", "bindings"],
        "properties": {
          "resourceId": { "type": "string", "minLength": 1 },
          "resourceKind": { "type": "string", "minLength": 1 },
          "providerId": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string" },
          "bindings": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["role", "objectId"],
              "properties": {
                "role": { "type": "string", "minLength": 1 },
                "objectId": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9_-]*(?:/[a-z0-9][a-z0-9_-]*){3}$"
                },
                "objectMeta": {
                  "type": "object",
                  "properties": {
                    "objectKind": { "type": "string" },
                    "encoding": { "type": "string" },
                    "sensitivity": { "type": "string" }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

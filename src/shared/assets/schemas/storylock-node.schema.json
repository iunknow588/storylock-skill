{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryLockNode",
  "type": "object",
  "required": ["nodeId", "title", "elementId", "question"],
  "properties": {
    "nodeId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "elementId": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "recommendedSelectionMode": { "type": "string" },
    "recommendedCorrectCount": { "type": "integer", "minimum": 1 },
    "candidatePoolSize": { "type": "integer", "minimum": 1 },
    "recallPriority": { "type": "integer", "minimum": 1 },
    "verifyPolicy": { "type": "string" },
    "editorNotes": { "type": "string" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryLockNode",
  "type": "object",
  "required": ["nodeId", "title", "elementId", "question"],
  "properties": {
    "nodeId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "elementId": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "recommendedSelectionMode": { "type": "string" },
    "recommendedCorrectCount": { "type": "integer", "minimum": 1 },
    "candidatePoolSize": { "type": "integer", "minimum": 1 },
    "answerOptionsLocalOnly": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["text", "isCorrect"],
        "properties": {
          "text": { "type": "string" },
          "isCorrect": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "canonicalAnswerLocalOnly": { "type": "string" },
    "acceptedAnswersLocalOnly": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recallPriority": { "type": "integer", "minimum": 1 },
    "verifyPolicy": { "type": "string" },
    "editorNotes": { "type": "string" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DelegatedSignatureInput",
  "type": "object",
  "required": ["identityId", "keyId", "algorithm", "payload", "requestId", "nonce", "expiry"],
  "properties": {
    "identityId": {
      "type": "string",
      "minLength": 1
    },
    "keyId": {
      "type": "string",
      "minLength": 1
    },
    "algorithm": {
      "type": "string",
      "enum": ["ed25519", "secp256k1"]
    },
    "payload": {},
    "action": {
      "type": "string",
      "default": "request_signature"
    },
    "scope": {
      "type": "string",
      "default": "signature_basic"
    },
    "resourceId": {
      "type": ["string", "null"]
    },
    "primaryRole": {
      "type": ["string", "null"]
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "nonce": {
      "type": "string",
      "minLength": 1
    },
    "expiry": {
      "type": "number"
    },
    "requestedRetention": {
      "type": "string",
      "enum": ["none", "result_only", "audit_meta_only"],
      "default": "result_only"
    },
    "policyHints": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "additionalProperties": false
}
